    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  },
